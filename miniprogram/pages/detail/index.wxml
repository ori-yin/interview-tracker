<!-- 详情页 -->
<view class="container" wx:if="{{application}}">
  <!-- 基本信息卡片 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">{{application.companyName}}</text>
      <t-tag
        variant="dark"
        shape="round"
        theme="{{application.statusTheme}}"
      >
        {{application.statusText}}
      </t-tag>
    </view>
    <text class="card-subtitle">{{application.positionName}}</text>

    <view class="divider"></view>

    <view class="info-list">
      <view class="info-row">
        <text class="info-label">投递日期</text>
        <text class="info-value">{{application.appliedDateFull}}</text>
      </view>
      <view class="info-row" wx:if="{{application.location}}">
        <text class="info-label">工作地点</text>
        <text class="info-value">{{application.location}}</text>
      </view>
      <view class="info-row" wx:if="{{application.salaryRange}}">
        <text class="info-label">薪资范围</text>
        <text class="info-value">{{application.salaryRange}}</text>
      </view>
    </view>

    <view class="notes-section" wx:if="{{application.notes}}">
      <text class="notes-label">备注</text>
      <text class="notes-content">{{application.notes}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="action-item" bindtap="goToEdit">
      <t-icon name="edit" size="40rpx" />
      <text class="action-text">编辑</text>
    </view>
    <view class="action-divider"></view>
    <view class="action-item" bindtap="onDeleteApplication">
      <t-icon name="delete" size="40rpx" color="#D4726A" />
      <text class="action-text action-text-danger">删除</text>
    </view>
  </view>

  <!-- 面试轮次列表 -->
  <view class="section-header">
    <text class="section-title">面试轮次</text>
    <t-tag
      variant="outline"
      shape="round"
      size="small"
      wx:if="{{interviewRounds.length > 0}}"
    >
      {{interviewRounds.length}} 轮
    </t-tag>
  </view>

  <view wx:if="{{interviewRounds.length === 0}}" class="card empty-card">
    <t-icon name="user" size="80rpx" color="#C0C0C7" />
    <text class="empty-text">暂无面试记录</text>
  </view>

  <view
    class="card round-card"
    wx:for="{{interviewRounds}}"
    wx:key="_id"
    bindtap="onRoundTap"
    data-index="{{index}}"
  >
    <view class="round-header">
      <text class="round-name">{{item.roundName}}</text>
      <t-tag
        variant="dark"
        shape="round"
        theme="{{item.result === 'passed' ? 'success' : (item.result === 'failed' ? 'danger' : (item.result === 'pending' ? 'warning' : 'default'))}}"
        size="small"
      >
        {{item.resultText}}
      </t-tag>
    </view>
    <view class="round-info">
      <text class="round-date">{{item.interviewDateFull}}</text>
      <text wx:if="{{item.interviewer}}" class="round-interviewer">{{item.interviewer}}</text>
    </view>
    <view wx:if="{{item.feedback}}" class="round-feedback">
      <text class="feedback-label">面试反馈</text>
      <text class="feedback-content">{{item.feedback}}</text>
    </view>
  </view>

  <!-- 添加面试轮次按钮 -->
  <view class="add-btn-wrap">
    <t-button theme="primary" variant="outline" block bind:tap="goToAddRound" icon="add">
      添加面试记录
    </t-button>
  </view>
</view>
