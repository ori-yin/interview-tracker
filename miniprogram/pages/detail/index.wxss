/* 详情页样式 */
.container {
  padding: var(--spacing-md);
  padding-bottom: var(--spacing-xl);
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.card-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
}

.card-subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-sm);
}

.divider {
  height: 1rpx;
  background: var(--color-neutral-100);
  margin: var(--spacing-sm) 0;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.notes-section {
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-neutral-100);
}

.notes-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.notes-content {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  background: var(--color-bg-input);
  padding: var(--spacing-sm);
  border-radius: var(--radius-md);
}

/* 操作按钮 - 水平排列 */
.action-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-1);
  margin-bottom: var(--spacing-sm);
  overflow: hidden;
}

.action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-md);
}

.action-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-neutral-100);
}

.action-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.action-text-danger {
  color: #D4726A;
}

/* 面试轮次 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: var(--spacing-md) 0 var(--spacing-sm);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-sm);
}

.round-card {
  transition: transform 0.15s ease;
}

.round-card:active {
  transform: scale(0.98);
}

.round-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.round-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.round-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: var(--spacing-xs);
}

.round-date,
.round-interviewer {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.round-feedback {
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-neutral-100);
}

.feedback-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.feedback-content {
  font-size: 24rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  background: var(--color-bg-input);
  padding: var(--spacing-sm);
  border-radius: var(--radius-md);
}

/* 添加按钮 */
.add-btn-wrap {
  margin: var(--spacing-sm) 0;
}
