/* 首页样式 */
.container {
  padding: var(--spacing-md);
  padding-bottom: 180rpx;
}

/* 统一卡片样式 */
.card-style {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-1);
  overflow: hidden;
}

/* 搜索栏 */
.search-section {
  margin-bottom: var(--spacing-sm);
}

/* 筛选栏 - 搜索框和标签同一行 */
.filter-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
}

.filter-tabs {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-1);
  overflow: hidden;
  min-height: 80rpx;
}

.filter-date {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-1);
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

/* 日期选择弹窗 */
.date-picker-popup {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-lg);
}

.date-picker-header {
  margin-bottom: var(--spacing-md);
}

.date-picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.date-presets {
  display: flex;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
}

.date-picker-footer {
  display: flex;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-lg);
}

/* 多选模式 */
.select-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-1);
  height: 72rpx;
  box-sizing: border-box;
}

.select-count {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

/* 列表卡片 */
.app-list {
  padding-bottom: var(--spacing-md);
}

.app-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-1);
}

.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.app-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.company-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
}

.separator {
  margin: 0 8rpx;
  color: var(--color-neutral-400);
  font-size: 22rpx;
}

.position-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

.date {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 流程进度条 */
.process-flow {
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-neutral-100);
}

.process-steps {
  display: flex;
  align-items: flex-start;
  overflow-x: auto;
}

.process-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  min-width: 56rpx;
  margin-right: 8rpx;
}

.step-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
  position: relative;
  z-index: 1;
}

.step-inner {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
}

.step-done {
  background: var(--color-neutral-100);
  border: 2rpx solid var(--color-neutral-200);
}

.step-done .step-inner {
  background: var(--color-neutral-400);
}

.step-current {
  background: rgba(232, 168, 85, 0.15);
  border: 2rpx solid var(--color-warning);
}

.step-current .step-inner {
  background: var(--color-warning);
}

.step-failed {
  background: rgba(212, 114, 106, 0.12);
  border: 2rpx solid var(--color-error);
}

.step-failed .step-inner {
  background: var(--color-error);
}

.step-offer {
  background: rgba(109, 191, 139, 0.15);
  border: 2rpx solid var(--color-success);
}

.step-offer .step-inner {
  background: var(--color-success);
}

.step-name {
  font-size: 14rpx;
  color: var(--color-text-tertiary);
  white-space: nowrap;
  text-align: center;
}

.step-name-current {
  color: var(--color-text-primary);
  font-weight: 600;
}

.step-line {
  position: absolute;
  top: 14rpx;
  left: 30rpx;
  width: 34rpx;
  height: 2rpx;
}

.line-done {
  background: var(--color-neutral-200);
}

.line-current {
  background: var(--color-warning);
}

.line-failed {
  background: var(--color-error);
}

/* 多选框 */
.checkbox-wrap {
  margin-right: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-full);
  border: 3rpx solid var(--color-neutral-300);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox-checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.checkbox-icon {
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

/* 底部删除按钮 */
.delete-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md) var(--spacing-lg);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 200;
}

/* 浮动添加按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 80rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-full);
  background: var(--color-text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-1);
  z-index: 100;
}

.fab:active {
  opacity: 0.85;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) 0;
}

.loading-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.no-more {
  display: flex;
  justify-content: center;
  padding: var(--spacing-md) 0;
}

.no-more-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}
